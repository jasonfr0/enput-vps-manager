<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  macOS Entitlements for Enput VPS Manager
  ─────────────────────────────────────────
  These entitlements are required for the app to run under Hardened Runtime
  (mandatory for notarization since macOS 10.15 Catalina).

  Hardened Runtime restricts what the process can do by default;
  each entitlement below explicitly re-enables a needed capability.
-->
<plist version="1.0">
<dict>

  <!-- ── JavaScript / JIT (required for V8 / Node.js) ───────────────────── -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- ── Unsigned executable memory (required by Electron's renderer) ────── -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- ── Disable library validation (allows loading non-Apple-signed dylibs) -->
  <!-- Needed for native Node modules (ssh2, etc.) -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>

  <!-- ── Network access (SSH/SFTP connections to VPS) ─────────────────────── -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- ── File read/write (SFTP file browser) ──────────────────────────────── -->
  <!-- User-selected read/write is automatically granted via file picker;
       this entitlement enables read access to user-selected locations -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>

  <!-- ── Downloads folder read/write ─────────────────────────────────────── -->
  <key>com.apple.security.files.downloads.read-write</key>
  <true/>

</dict>
</plist>
